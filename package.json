{
  "name": "openpadang",
  "version": "0.0.0",
  "private": true,
  "description": "Civic open data initiative untuk Padang & Sumbar — terbuka, terstandar, gratis.",
  "license": "MIT",
  "homepage": "https://github.com/superemem/openpadang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superemem/openpadang.git"
  },
  "scripts": {
    "dev:site": "pnpm --filter site dev",
    "dev:app": "pnpm --filter app dev",
